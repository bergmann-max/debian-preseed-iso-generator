# Profile variables for the 'minimal' profile.
# Filename must match the profile dir name: <profile>/<profile>.env
# Rendered into preseed.cfg via templates/preseed.cfg.tmpl + envsubst.

### Localization
LOCALE=en_US.UTF-8
KEYMAP=us

### Network
HOSTNAME=debian-minimal
DOMAIN=local

### Mirror
MIRROR_HOST=deb.debian.org
MIRROR_DIR=/debian
MIRROR_PROXY=

### Account setup
# Generate hash: mkpasswd -m sha-512
# Leave empty to be prompted at install time.
ROOT_PASSWORD_HASH=
USER_FULLNAME="Debian User"
USER_NAME=debian
USER_PASSWORD_HASH=

### Clock
TIMEZONE=UTC
# Empty = installer default (deb.debian.org NTP pool)
NTP_SERVER=

### Partitioning
# method: regular | lvm | crypto
PARTITION_METHOD=lvm
# size: 'max', '20 GB', '80%', etc.
LVM_SIZE=max
# recipe: atomic | home | multi | server | small_disk
PARTITION_RECIPE=atomic

### APT
APT_NON_FREE_FIRMWARE=false
APT_NON_FREE=false
APT_CONTRIB=false

### Package selection
# tasksel tasks (comma-separated). 'standard' = base system only.
TASKS=standard
# extra packages (space-separated). Empty = none.
PACKAGES=
# upgrade: none | safe-upgrade | full-upgrade
UPGRADE_POLICY=safe-upgrade
# popularity-contest opt-in
POPCON=false

### Boot loader (GRUB)
GRUB_ONLY_DEBIAN=true
GRUB_WITH_OTHER_OS=true

### Late command (runs in installer just before reboot; '' = no-op)
LATE_COMMAND=
